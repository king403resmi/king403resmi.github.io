---
layout: null
permalink: /sitemap.xml
sitemap: false
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:xhtml="http://www.w3.org/1999/xhtml">
  <url>
    <loc>{{ site.url }}/</loc>
    <lastmod>2026-06-13</lastmod>
    <changefreq>weekly</changefreq>
    <priority>1.0</priority>
    <xhtml:link rel="alternate" hreflang="id" href="{{ site.url }}/"/>
    <xhtml:link rel="alternate" hreflang="x-default" href="{{ site.official.site }}/"/>
  </url>
{%- assign sitemap_pages = "profil-digital,tentang,layanan,testimoni,proyek,teknologi,berita,mitra,tim,karir,faq,kontak,kebijakan-privasi,syarat-ketentuan" | split: "," -%}
{%- for slug in sitemap_pages -%}
  {%- assign page_path = slug | append: ".md" -%}
  {%- assign sp = site.pages | where: "path", page_path | first -%}
  {%- if sp -%}
  <url>
    <loc>{{ sp.url | absolute_url }}</loc>
    <lastmod>2026-06-13</lastmod>
    <changefreq>{% if slug == 'berita' or slug == 'karir' %}weekly{% else %}monthly{% endif %}</changefreq>
    <priority>{% if slug == 'profil-digital' or slug == 'tentang' %}0.95{% elsif slug == 'faq' or slug == 'kontak' or slug == 'layanan' %}0.90{% else %}0.80{% endif %}</priority>
  </url>
  {%- endif -%}
{%- endfor -%}
</urlset>
